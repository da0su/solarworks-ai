# Playwright persistent session (cookie / cache) — never commit
state/wp_session/
state/*.json

# 実行時に生成される logs / screenshots
logs/
screenshots/

# v3: ZIP 展開した素材 (約 82MB, アセット原本は別途 Box 管理)
materials_v3/

# python cache
__pycache__/
*.pyc

# 認証ファイル類 (basecredentials.py が外部 Box から読み込むので
# このディレクトリ内に置かれないが念のため)
.env
*.env
*credentials*.txt
