# ROOM BOT 環境設定
# このファイルを .env にコピーして値を設定してください
# cp .env.example .env

# 楽天API
RAKUTEN_APP_ID=
RAKUTEN_ACCESS_KEY=

# Slack BOT（CEOコマンド連携）
# 1. https://api.slack.com/apps で新しいAppを作成
# 2. Socket Mode を有効化 → App-Level Token を生成
# 3. Bot Token Scopes: chat:write, app_mentions:read
# 4. Event Subscriptions: message.channels, message.im, app_mention
# 5. Install App → Bot User OAuth Token をコピー
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
