    "update_procedure": [
      "1. 各オークション社の公式サイトまたはカタログでBuyer's Premiumを確認",
      "2. キャップが本ファイルを更新",
      "3. CEOに変更内容を報告・承認取得",
      "4. ceo_confirmed を true に変更",
      "5. git commit して記録"
    ],
    "formula": {
      "description": "仕入れコスト計算式（各オークション共通構造）",
      "step1": "hammer_price × (1 + buyer_premium_pct + cc_fee_pct) = subtotal_in_currency",
      "step2": "subtotal_in_currency × fx_rate × (1 + fx_buffer_pct) = subtotal_jpy",
      "step3": "subtotal_jpy + shipping_usd × fx_rate + transfer_jpy + insurance_jpy + other_fees_jpy = pretax_jpy",
      "step4": "pretax_jpy × (1 + import_tax_pct) = total_cost_jpy",
      "note": "import_tax_pct: 金貨・銀貨とも0%（CEO確定 2026-03-30）"
    },
    "buy_limit_formula": {
      "description": "仕入れ上限（ハンマー価格）の逆算式",
      "input": "yahoo_sell_jpy: ヤフオク想定売値(円), domestic_fee_jpy: 国内送料+手数料(¥750想定)",
      "net_sell": "yahoo_sell_jpy × 0.9 - domestic_fee_jpy",
      "available_20k": "net_sell - 20000",
      "available_15pct": "net_sell × 0.85",
      "hammer_limit": "(available / (1 + import_tax_pct) - shipping_usd × fx_rate - transfer_jpy) / (fx_rate × (1 + fx_buffer_pct) × (1 + buyer_premium_pct + cc_fee_pct))",
      "note": "基準1=ref1_yahoo_price基準, 基準2=ref2_yahoo_price基準。4値とも同式でavailableの起点が異なるだけ。"
    }
  },
