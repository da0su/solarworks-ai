# ==============================================================
# SolarWorks AI — 環境変数テンプレート
# ==============================================================
# このファイルをコピーして .env を作成してください。
# 実値を入れた .env は絶対にGitにcommitしないでください。
#
# cp .env.example .env
# → 各値を実際のキーで埋める
# ==============================================================

# --------------------------------------------------------------
# Slack Bridge（ルート直下 .env）
# --------------------------------------------------------------
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# --------------------------------------------------------------
# 楽天ROOM BOT（rakuten-room/bot/.env）
# --------------------------------------------------------------
RAKUTEN_APP_ID=your-rakuten-app-id
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# --------------------------------------------------------------
# コイン仕入れリサーチ（coin_business/.env）
# --------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key
EBAY_CLIENT_ID=your-ebay-client-id
EBAY_CLIENT_SECRET=your-ebay-client-secret

# --------------------------------------------------------------
# オプション（通知・音声）
# --------------------------------------------------------------
# SOLARWORKS_SLACK_WEBHOOK=https://hooks.slack.com/services/...
# VOICEVOX_URL=http://localhost:50021
