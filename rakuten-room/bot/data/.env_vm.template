# ============================================================
# .env_vm — VM v6 用 credential ファイル (Plan v6)
# ============================================================
# このファイルは shared folder vm_data 経由で VM が読み込みます。
# 場所:
#   HOST: rakuten-room\bot\data\.env_vm
#   VM 内マウントパス: \\vboxsvr\vm_data\.env_vm  (= C:\Users\cyber\Desktop\rakuten_room_bot\data\.env_vm)
#
# 使い方:
#   1) このテンプレートを `.env_vm` という名前でコピー
#      (HOST 側で:  copy .env_vm.template .env_vm)
#   2) 下記の値を埋める
#   3) chmod / 権限は通常 OK (HOST PC の自分しかアクセスしない領域)
# ============================================================

# 楽天ID ログインパスワード (POST 等の session/upgrade 自動通過に使用)
# 楽天 ID (例: sunahiro1022@gmail.com) は楽天が cookie 経由で既知。password のみ必要。
RAKUTEN_LOGIN_PASSWORD=

# 楽天 API Application ID (rakuten-room/bot/.env と同じ値で OK)
RAKUTEN_APP_ID=

# Slack 通知 (オプション・VM 内から直接 Slack に投げる場合)
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
